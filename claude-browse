#!/usr/bin/env python3
"""claude-browse: Browse, search, and resume Claude Code sessions.

An interactive TUI for navigating your Claude Code conversation history.
Lists all sessions across projects with full-text search, conversation
history viewing, and one-key resume.

Requirements:
  - Python 3.7+
  - Claude Code CLI installed and on your PATH

Environment variables:
  CLAUDE_BROWSE_CMD   Command used to resume sessions (default: "claude").
                      Set this if your Claude Code binary has a different
                      name or path, or to pass default CLI flags.
                      Examples:
                        CLAUDE_BROWSE_CMD="claude-code"
                        CLAUDE_BROWSE_CMD="claude --dangerously-skip-permissions"

Usage:
  claude-browse                    Interactive session browser
  claude-browse -s "search term"   Open with search results
  claude-browse -n 20              Show only the 20 most recent sessions
  claude-browse --json             Dump session list as JSON (non-interactive)
  claude-browse --session ID       Jump to a specific session by ID
  claude-browse --session ID --history   Print session history to stdout

Flags:
  -n N              Limit to N most recent sessions
  -s QUERY          Pre-fill search with QUERY
  --json            Output session list as JSON and exit
  --full-path       Show full project paths instead of shortened ones
  --session ID      Jump directly to a session (prefix match supported)
  --history         With --session, print conversation history to stdout
  --no-tools        Hide tool use/result blocks in history output
  --thinking        Include thinking blocks in history output
  --no-color        Disable colored output

Interactive keys:
  Session list:  j/k or Up/Down to navigate, Enter to select,
                 s or / to search, g/G for top/bottom,
                 PgUp/PgDn to page, q or Esc to quit
  Action screen: r to resume (default Enter), h to view history,
                 Esc to go back
"""

import argparse
import curses
import datetime
import json
import os
import re
import shlex
import sys
import textwrap
from pathlib import Path
from typing import Dict, List, Optional, Tuple

CLAUDE_CMD = os.environ.get("CLAUDE_BROWSE_CMD", "claude")
CLAUDE_DIR = Path.home() / ".claude" / "projects"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def decode_project_dir(dirname):
    """Convert encoded dir name back to a filesystem path.

    Claude encodes paths by replacing '/' with '-', but directory names
    themselves may contain hyphens.  We resolve ambiguity by walking the
    filesystem: at each level we try the longest segment that matches an
    existing directory, falling back to shorter splits.
    """
    # The encoded name starts with a leading '-' representing the root '/'.
    if dirname.startswith("-"):
        parts = dirname[1:].split("-")  # drop leading empty segment
    else:
        parts = dirname.split("-")

    if not parts:
        return "/" + dirname.replace("-", "/")

    # Greedy left-to-right resolution against the real filesystem.
    resolved = "/"
    i = 0
    while i < len(parts):
        # Try joining as many consecutive parts as possible (longest match).
        matched = False
        for end in range(len(parts), i, -1):
            candidate = "-".join(parts[i:end])
            test_path = os.path.join(resolved, candidate)
            if os.path.exists(test_path):
                resolved = test_path
                i = end
                matched = True
                break
        if not matched:
            # No filesystem match — just use the single part and keep going.
            resolved = os.path.join(resolved, parts[i])
            i += 1

    return resolved


def _extract_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for part in content:
            if isinstance(part, dict) and part.get("type") == "text":
                parts.append(part.get("text", ""))
        return " ".join(parts)
    return ""


def _strip_xml_tags(text):
    return re.sub(r"<[^>]+>", "", text).strip()


def _parse_iso(ts):
    if not ts:
        return None
    try:
        ts = ts.replace("Z", "+00:00")
        if "." in ts:
            base, frac_and_tz = ts.split(".", 1)
            frac_match = re.match(r"(\d+)(.*)", frac_and_tz)
            if frac_match:
                frac = frac_match.group(1)[:6].ljust(6, "0")
                tz_part = frac_match.group(2)
                ts = base + "." + frac + tz_part
        return datetime.datetime.strptime(
            ts.replace("+00:00", "+0000").replace(":", ""),
            "%Y%m%dT%H%M%S.%f%z" if "." in ts else "%Y%m%dT%H%M%S%z",
        )
    except (ValueError, IndexError):
        return None


def relative_date(dt):
    if dt is None:
        return "unknown"
    now = datetime.datetime.now(datetime.timezone.utc)
    delta = now - dt
    seconds = int(delta.total_seconds())
    if seconds < 60:
        return "just now"
    minutes = seconds // 60
    if minutes < 60:
        return "{} min ago".format(minutes)
    hours = minutes // 60
    if hours < 24:
        return "{} hr ago".format(hours)
    days = delta.days
    if days == 1:
        return "yesterday"
    if days < 30:
        return "{} days ago".format(days)
    return dt.strftime("%Y-%m-%d")


def shorten_path(path, full=False):
    home = str(Path.home())
    if path.startswith(home):
        path = "~" + path[len(home):]
    if full or len(path) <= 50:
        return path
    parts = path.split("/")
    if len(parts) <= 3:
        return path
    return parts[0] + "/" + parts[1] + "/.../" + parts[-1]


def session_description(session, max_len=80):
    desc = session.get("summary") or session.get("first_prompt") or session.get("last_prompt") or ""
    desc = _strip_xml_tags(desc)
    desc = " ".join(desc.split())
    if len(desc) > max_len:
        desc = desc[:max_len - 3] + "..."
    return desc


def wrap_text(text, width):
    words = text.split()
    lines = []
    current = ""
    for w in words:
        if current and len(current) + 1 + len(w) > width:
            lines.append(current)
            current = w
        else:
            current = current + " " + w if current else w
    if current:
        lines.append(current)
    return lines or [""]


# ---------------------------------------------------------------------------
# Data collection
# ---------------------------------------------------------------------------

def _parse_jsonl_meta(filepath):
    """Parse a session .jsonl file and return session metadata dict."""
    first_user_prompt = ""
    last_prompt = ""
    session_id = ""
    timestamp = None
    last_ts = None
    msg_count = 0

    try:
        with open(str(filepath), "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue

                entry_type = entry.get("type", "")

                if entry_type == "last-prompt":
                    last_prompt = entry.get("lastPrompt", "")
                    if not session_id:
                        session_id = entry.get("sessionId", "")
                    continue

                if entry_type in ("user", "assistant"):
                    msg_count += 1
                    ts = _parse_iso(entry.get("timestamp", ""))
                    if ts:
                        if timestamp is None:
                            timestamp = ts
                        last_ts = ts

                if entry_type == "user" and not entry.get("isMeta"):
                    if not session_id:
                        session_id = entry.get("sessionId", "")
                    text = _extract_text(entry.get("message", {}).get("content", ""))
                    text = _strip_xml_tags(text)
                    if text and not first_user_prompt:
                        first_user_prompt = " ".join(text.split())

    except (IOError, OSError):
        return None

    if not session_id:
        session_id = filepath.stem

    if timestamp is None and last_ts is None:
        try:
            mtime = filepath.stat().st_mtime
            last_ts = datetime.datetime.fromtimestamp(mtime, tz=datetime.timezone.utc)
        except OSError:
            pass

    return {
        "session_id": session_id,
        "first_prompt": first_user_prompt,
        "last_prompt": last_prompt,
        "summary": "",
        "msg_count": msg_count,
        "timestamp": timestamp,
        "last_timestamp": last_ts,
        "jsonl_path": str(filepath),
    }


def _load_sessions_index(index_path, project_dir_path):
    result = {}
    try:
        with open(str(index_path), "r") as f:
            data = json.load(f)
        for entry in data.get("entries", []):
            sid = entry.get("sessionId", "")
            if sid:
                jsonl_path = project_dir_path / (sid + ".jsonl")
                result[sid] = {
                    "session_id": sid,
                    "summary": entry.get("summary", ""),
                    "first_prompt": entry.get("firstPrompt", ""),
                    "last_prompt": entry.get("lastPrompt", ""),
                    "msg_count": entry.get("messageCount", 0),
                    "timestamp": _parse_iso(entry.get("createdAt", "")),
                    "last_timestamp": _parse_iso(entry.get("updatedAt", "")),
                    "jsonl_path": str(jsonl_path),
                }
    except (IOError, OSError, json.JSONDecodeError):
        pass
    return result


def collect_sessions():
    sessions = []
    if not CLAUDE_DIR.is_dir():
        return sessions

    for project_dir in CLAUDE_DIR.iterdir():
        if not project_dir.is_dir():
            continue

        dir_name = project_dir.name
        project_path = decode_project_dir(dir_name)

        index_path = project_dir / "sessions-index.json"
        indexed = _load_sessions_index(index_path, project_dir)
        indexed_ids = set(indexed.keys())

        for sid, info in indexed.items():
            info["project_path"] = project_path
            info["project_dir"] = dir_name
            sessions.append(info)

        for jsonl_file in project_dir.glob("*.jsonl"):
            sid = jsonl_file.stem
            if sid in indexed_ids:
                continue
            info = _parse_jsonl_meta(jsonl_file)
            if info:
                info["project_path"] = project_path
                info["project_dir"] = dir_name
                sessions.append(info)

    return sessions


# ---------------------------------------------------------------------------
# Filtering & sorting
# ---------------------------------------------------------------------------

_TRIVIAL_PROMPTS = {"hello", "hi", "hey", ""}


def is_trivial(session):
    if session.get("msg_count", 0) <= 3:
        prompt = (session.get("summary") or session.get("first_prompt") or "").strip().lower()
        prompt = _strip_xml_tags(prompt)
        if prompt in _TRIVIAL_PROMPTS:
            return True
    return False


def filter_sessions(sessions):
    return [s for s in sessions if not is_trivial(s)]


def sort_sessions(sessions):
    def sort_key(s):
        ts = s.get("last_timestamp") or s.get("timestamp")
        if ts:
            return ts
        return datetime.datetime(2000, 1, 1, tzinfo=datetime.timezone.utc)
    return sorted(sessions, key=sort_key, reverse=True)


# ---------------------------------------------------------------------------
# Full-text search (from claude-search)
# ---------------------------------------------------------------------------

def _scan_jsonl_for_search(filepath, terms):
    """Parse a session .jsonl, searching for terms in all text content.

    Returns session info dict augmented with search scoring, or None if no matches.
    """
    session_id = ""
    first_user_prompt = ""
    first_prompt_full = ""
    last_prompt = ""
    timestamp = None
    last_ts = None
    msg_count = 0
    summary = ""
    all_text_chunks = []

    try:
        with open(str(filepath), "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue

                entry_type = entry.get("type", "")

                if entry_type == "last-prompt":
                    last_prompt = entry.get("lastPrompt", "")
                    if not session_id:
                        session_id = entry.get("sessionId", "")
                    all_text_chunks.append(last_prompt.lower())
                    continue

                if entry_type == "summary":
                    summary = entry.get("summary", "")
                    all_text_chunks.append(summary.lower())
                    continue

                if entry_type in ("user", "assistant"):
                    msg_count += 1
                    ts = _parse_iso(entry.get("timestamp", ""))
                    if ts:
                        if timestamp is None:
                            timestamp = ts
                        last_ts = ts

                if entry_type == "user" and not entry.get("isMeta"):
                    if not session_id:
                        session_id = entry.get("sessionId", "")
                    text = _extract_text(entry.get("message", {}).get("content", ""))
                    text = _strip_xml_tags(text)
                    if text:
                        if not first_user_prompt:
                            first_user_prompt = " ".join(text.split())
                            first_prompt_full = first_user_prompt
                        all_text_chunks.append(text.lower())

                if entry_type == "assistant":
                    text = _extract_text(entry.get("message", {}).get("content", ""))
                    if text:
                        all_text_chunks.append(text.lower())

    except (IOError, OSError):
        return None

    if not session_id:
        session_id = filepath.stem

    full_text = " ".join(all_text_chunks)
    terms_matched = 0
    total_hits = 0

    for term in terms:
        count = full_text.count(term)
        if count > 0:
            terms_matched += 1
            total_hits += count

    if terms_matched == 0:
        return None

    if timestamp is None and last_ts is None:
        try:
            mtime = filepath.stat().st_mtime
            last_ts = datetime.datetime.fromtimestamp(mtime, tz=datetime.timezone.utc)
        except OSError:
            pass

    preview = first_prompt_full[:200] if first_prompt_full else "(no prompt)"

    return {
        "session_id": session_id,
        "first_prompt": first_user_prompt[:80] if first_user_prompt else "",
        "preview": preview,
        "last_prompt": last_prompt,
        "summary": summary,
        "msg_count": msg_count,
        "timestamp": timestamp,
        "last_timestamp": last_ts,
        "jsonl_path": str(filepath),
        "terms_matched": terms_matched,
        "total_hits": total_hits,
    }


def search_all_sessions(terms):
    results = []
    if not CLAUDE_DIR.is_dir():
        return results

    for project_dir in CLAUDE_DIR.iterdir():
        if not project_dir.is_dir():
            continue

        dir_name = project_dir.name
        project_path = decode_project_dir(dir_name)

        for jsonl_file in project_dir.glob("*.jsonl"):
            info = _scan_jsonl_for_search(jsonl_file, terms)
            if info:
                info["project_path"] = project_path
                info["project_dir"] = dir_name
                results.append(info)

    return sorted(results, key=lambda r: (r["terms_matched"], r["total_hits"]), reverse=True)


# ---------------------------------------------------------------------------
# History extraction (from claude-history)
# ---------------------------------------------------------------------------

def _format_timestamp(ts_str):
    dt = _parse_iso(ts_str)
    if dt is None:
        return ""
    local_dt = dt.astimezone()
    return local_dt.strftime("%Y-%m-%d %H:%M:%S")


def _extract_content_blocks(content):
    blocks = []
    if isinstance(content, str):
        blocks.append(("text", content))
    elif isinstance(content, list):
        for part in content:
            if isinstance(part, dict):
                btype = part.get("type", "")
                if btype == "text":
                    blocks.append(("text", part.get("text", "")))
                elif btype == "thinking":
                    thinking_text = part.get("thinking", "")
                    if thinking_text:
                        blocks.append(("thinking", thinking_text))
                elif btype == "tool_use":
                    name = part.get("name", "unknown")
                    inp = part.get("input", {})
                    summary = _summarize_tool_use(name, inp)
                    blocks.append(("tool_use", summary))
                elif btype == "tool_result":
                    tool_content = part.get("content", "")
                    if isinstance(tool_content, list):
                        for sub in tool_content:
                            if isinstance(sub, dict) and sub.get("type") == "text":
                                tool_content = sub.get("text", "")
                                break
                        else:
                            tool_content = str(tool_content)
                    is_err = part.get("is_error", False)
                    prefix = "[tool error] " if is_err else "[tool result] "
                    if isinstance(tool_content, str) and len(tool_content) > 500:
                        tool_content = tool_content[:500] + "... (truncated)"
                    blocks.append(("tool_result", prefix + str(tool_content)))
                elif btype == "image":
                    blocks.append(("text", "[image]"))
                elif btype == "document":
                    blocks.append(("text", "[document]"))
            elif isinstance(part, str):
                blocks.append(("text", part))
    return blocks


def _summarize_tool_use(name, inp):
    if name in ("Read", "read"):
        return "[tool: Read {}]".format(inp.get("file_path", ""))
    elif name in ("Write", "write"):
        return "[tool: Write {}]".format(inp.get("file_path", ""))
    elif name in ("Edit", "edit"):
        return "[tool: Edit {}]".format(inp.get("file_path", ""))
    elif name in ("Bash", "bash"):
        cmd = inp.get("command", "")
        if len(cmd) > 120:
            cmd = cmd[:117] + "..."
        return "[tool: Bash] {}".format(cmd)
    elif name in ("Glob", "glob"):
        return "[tool: Glob {}]".format(inp.get("pattern", ""))
    elif name in ("Grep", "grep"):
        return "[tool: Grep '{}' {}]".format(inp.get("pattern", ""), inp.get("path", ""))
    elif name == "Agent":
        desc = inp.get("description", "")
        return "[tool: Agent] {}".format(desc)
    elif name in ("TodoWrite", "TaskCreate", "TaskUpdate"):
        return "[tool: {}]".format(name)
    else:
        summary = "[tool: {}]".format(name)
        for k, v in inp.items():
            if isinstance(v, str) and v and len(v) < 100:
                summary += " {}={}".format(k, v)
                break
        return summary


def read_session_history(session, include_thinking=False, include_tools=True):
    jsonl_path = session.get("jsonl_path", "")
    if not jsonl_path:
        project_dir = session.get("project_dir", "")
        session_id = session.get("session_id", "")
        jsonl_path = str(CLAUDE_DIR / project_dir / (session_id + ".jsonl"))

    entries = []
    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue

                entry_type = entry.get("type", "")
                if entry_type not in ("user", "assistant"):
                    continue

                if entry.get("isSidechain", False):
                    continue

                role = entry_type
                timestamp = entry.get("timestamp", "")
                content = entry.get("message", {}).get("content", "")
                model = entry.get("message", {}).get("model", "")

                blocks = _extract_content_blocks(content)

                filtered = []
                for btype, text in blocks:
                    if btype == "thinking" and not include_thinking:
                        continue
                    if btype in ("tool_use", "tool_result") and not include_tools:
                        continue
                    filtered.append((btype, text))

                if not filtered:
                    continue

                entries.append({
                    "role": role,
                    "timestamp": timestamp,
                    "model": model,
                    "blocks": filtered,
                })
    except (IOError, OSError) as e:
        print("Error reading session file: {}".format(e), file=sys.stderr)
        return []

    return entries


def print_history(session, entries, use_color=True):
    RESET = "\033[0m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    CYAN = "\033[36m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    MAGENTA = "\033[35m"

    def c(code, text):
        if use_color:
            return "{}{}{}".format(code, text, RESET)
        return text

    desc = session_description(session)
    project = shorten_path(session.get("project_path", ""), full=True)
    ts = session.get("timestamp")
    last_ts = session.get("last_timestamp")

    print(c(BOLD, "=" * 72))
    print(c(BOLD, "Session: ") + session.get("session_id", ""))
    print(c(BOLD, "Project: ") + project)
    if desc:
        print(c(BOLD, "Description: ") + desc)
    if ts:
        if hasattr(ts, 'astimezone'):
            print(c(BOLD, "Started: ") + ts.astimezone().strftime("%Y-%m-%d %H:%M:%S"))
        else:
            print(c(BOLD, "Started: ") + _format_timestamp(str(ts)))
    if last_ts:
        if hasattr(last_ts, 'astimezone'):
            print(c(BOLD, "Last activity: ") + last_ts.astimezone().strftime("%Y-%m-%d %H:%M:%S"))
        else:
            print(c(BOLD, "Last activity: ") + _format_timestamp(str(last_ts)))
    print(c(BOLD, "Messages: ") + str(len(entries)))
    print(c(BOLD, "=" * 72))
    print()

    for entry in entries:
        role = entry["role"]
        timestamp = _format_timestamp(entry["timestamp"])

        if role == "user":
            header = c(GREEN + BOLD, "USER")
        else:
            model = entry.get("model", "")
            model_short = model.split("/")[-1] if "/" in model else model
            header = c(CYAN + BOLD, "ASSISTANT")
            if model_short:
                header += c(DIM, " [{}]".format(model_short))

        if timestamp:
            header += c(DIM, "  {}".format(timestamp))

        print(header)
        print(c(DIM, "-" * 40))

        for btype, text in entry["blocks"]:
            if btype == "thinking":
                print(c(MAGENTA + DIM, "<thinking>"))
                print(c(DIM, text))
                print(c(MAGENTA + DIM, "</thinking>"))
            elif btype == "tool_use":
                print(c(YELLOW, text))
            elif btype == "tool_result":
                print(c(DIM, text))
            else:
                cleaned = re.sub(
                    r"<system-reminder>.*?</system-reminder>",
                    "",
                    text,
                    flags=re.DOTALL,
                )
                cleaned = cleaned.strip()
                if cleaned:
                    print(cleaned)

        print()


# ---------------------------------------------------------------------------
# Resume
# ---------------------------------------------------------------------------

def resume_session(session):
    project_path = session["project_path"]
    session_id = session["session_id"]
    shell = os.environ.get("SHELL", "/bin/sh")
    os.execvp(shell, [shell, "-ic", "cd {} && {} --resume {}".format(
        shlex.quote(project_path), CLAUDE_CMD, session_id
    )])


