def _draw_session_list(stdscr, sessions, selected, offset, max_y, max_x,
                       header_text, search_mode=False, search_terms=None):
    """Draw the session list view. Returns visible_entries count."""
    LINES_PER_ENTRY = 3

    # Header
    try:
        stdscr.addnstr(0, 0, header_text.ljust(max_x), max_x,
                        curses.A_REVERSE | curses.A_BOLD)
    except curses.error:
        pass

    # Footer
    if sessions:
        footer_pos = " {}/{} ".format(selected + 1, len(sessions))
    else:
        footer_pos = " 0/0 "
    if search_mode:
        footer_keys = " \u2191\u2193/jk:nav  Enter:select  Esc:back to list  q:quit "
    else:
        footer_keys = " \u2191\u2193/jk:nav  Enter:select  s or /:search  q/Esc:quit "
    footer = footer_pos + footer_keys
    try:
        stdscr.addnstr(max_y - 1, 0, footer.ljust(max_x), max_x, curses.A_REVERSE)
    except curses.error:
        pass

    if not sessions:
        msg = "  No sessions found."
        try:
            stdscr.addnstr(2, 0, msg, max_x)
        except curses.error:
            pass
        return 0

    content_height = max_y - 2
    visible_entries = max(1, content_height // LINES_PER_ENTRY)

    y = 1
    for i in range(offset, min(offset + visible_entries, len(sessions))):
        session = sessions[i]
        is_sel = (i == selected)

        ts = session.get("last_timestamp") or session.get("timestamp")
        date_str = relative_date(ts)
        path_str = shorten_path(session.get("project_path", ""))
        desc = session_description(session)
        meta_parts = ["msgs: {}".format(session.get("msg_count", 0))]
        if search_terms and session.get("terms_matched"):
            meta_parts.append("{}/{} terms, {} hits".format(
                session["terms_matched"], len(search_terms), session["total_hits"]
            ))
        meta = "  ".join(meta_parts)

        line1 = "  {} | {}".format(date_str, path_str)
        line2 = "    {}".format(desc) if desc else "    (no description)"
        line3 = "    {}".format(meta)

        if is_sel:
            attr = curses.color_pair(1) | curses.A_BOLD
            for ln, text in enumerate([line1, line2, line3]):
                if y + ln < max_y - 1:
                    try:
                        stdscr.addnstr(y + ln, 0, text.ljust(max_x), max_x, attr)
                    except curses.error:
                        pass
        else:
            if y < max_y - 1:
                try:
                    stdscr.addnstr(y, 0, line1, max_x, curses.color_pair(2))
                except curses.error:
                    pass
            if y + 1 < max_y - 1:
                try:
                    stdscr.addnstr(y + 1, 0, line2, max_x)
                except curses.error:
                    pass
            if y + 2 < max_y - 1:
                try:
                    stdscr.addnstr(y + 2, 0, line3, max_x, curses.A_DIM)
                except curses.error:
                    pass

        y += LINES_PER_ENTRY

    return visible_entries


def _draw_action_screen(stdscr, session, max_y, max_x, action_selected):
    """Draw the action screen for a selected session."""
    # Header
    header = " Session Details "
    try:
        stdscr.addnstr(0, 0, header.ljust(max_x), max_x,
                        curses.A_REVERSE | curses.A_BOLD)
    except curses.error:
        pass

    y = 2

    # Session details - use more screen real estate
    project = shorten_path(session.get("project_path", ""), full=True)
    ts = session.get("timestamp")
    last_ts = session.get("last_timestamp")
    sid = session.get("session_id", "")
    msg_count = session.get("msg_count", 0)

    details = [
        ("Project:", project),
        ("Session ID:", sid),
    ]
    if ts:
        if hasattr(ts, 'astimezone'):
            details.append(("Started:", ts.astimezone().strftime("%Y-%m-%d %H:%M:%S")))
        else:
            details.append(("Started:", str(ts)))
    if last_ts:
        if hasattr(last_ts, 'astimezone'):
            details.append(("Last active:", last_ts.astimezone().strftime("%Y-%m-%d %H:%M:%S")))
        else:
            details.append(("Last active:", str(last_ts)))
    details.append(("Messages:", str(msg_count)))

    for label, value in details:
        if y < max_y - 4:
            try:
                stdscr.addnstr(y, 2, label, max_x - 2, curses.A_BOLD)
                stdscr.addnstr(y, 2 + len(label) + 1, value, max_x - len(label) - 3)
            except curses.error:
                pass
            y += 1

    y += 1

    # Show chat history preview from the start of the conversation
    # Reserve 4 lines at bottom: blank, "Actions:" label, 2 action items
    actions_height = 4
    # footer takes 1 line, so usable bottom is max_y - 1
    chat_bottom = max_y - 1 - actions_height
    chat_width = max(20, max_x - 6)

    if y < chat_bottom:
        try:
            stdscr.addnstr(y, 2, "Chat preview:", max_x - 2, curses.A_BOLD)
        except curses.error:
            pass
        y += 1

    # Load history entries (cached on the session dict to avoid re-reading)
    if "_history_cache" not in session:
        session["_history_cache"] = read_session_history(
            session, include_thinking=False, include_tools=False
        )
    entries = session["_history_cache"]

    if entries and y < chat_bottom:
        try:
            stdscr.addnstr(y, 2, "\u2500" * min(chat_width, max_x - 4),
                            max_x - 2, curses.A_DIM)
        except curses.error:
            pass
        y += 1

    for entry in entries:
        if y >= chat_bottom:
            break

        role = entry["role"]
        if role == "user":
            role_attr = curses.color_pair(3) | curses.A_BOLD  # green
            role_label = "USER: "
        else:
            role_attr = curses.color_pair(4) | curses.A_BOLD  # cyan
            role_label = "ASSISTANT: "

        # Collect text blocks into one string
        text_parts = []
        for btype, text in entry["blocks"]:
            if btype == "text":
                cleaned = re.sub(
                    r"<system-reminder>.*?</system-reminder>", "", text,
                    flags=re.DOTALL,
                )
                cleaned = _strip_xml_tags(cleaned)
                cleaned = " ".join(cleaned.split())
                if cleaned:
                    text_parts.append(cleaned)
        full_text = " ".join(text_parts)
        if not full_text:
            continue

        # First line: role label + start of text
        first_line_width = max(10, chat_width - len(role_label))
        if len(full_text) <= first_line_width:
            first_line = full_text
            remaining = ""
        else:
            first_line = full_text[:first_line_width]
            remaining = full_text[first_line_width:]

        if y < chat_bottom:
            try:
                stdscr.addnstr(y, 4, role_label, max_x - 4, role_attr)
                stdscr.addnstr(y, 4 + len(role_label), first_line,
                                max_x - 4 - len(role_label))
            except curses.error:
                pass
            y += 1

        # Continuation lines (indented to align with text after label)
        if remaining:
            cont_lines = wrap_text(remaining, chat_width)
            # Limit continuation lines per message to keep it readable
            max_cont = min(3, chat_bottom - y)
            for i, cline in enumerate(cont_lines[:max_cont]):
                if y >= chat_bottom:
                    break
                try:
                    stdscr.addnstr(y, 4 + len(role_label), cline,
                                    max_x - 4 - len(role_label))
                except curses.error:
                    pass
                y += 1
            if len(cont_lines) > max_cont and y < chat_bottom:
                try:
                    stdscr.addnstr(y, 4 + len(role_label), "...",
                                    max_x - 4 - len(role_label), curses.A_DIM)
                except curses.error:
                    pass
                y += 1

    # If we ran out of entries before space, or no entries
    if not entries and y < chat_bottom:
        try:
            stdscr.addnstr(y, 4, "(no messages found)", max_x - 4, curses.A_DIM)
        except curses.error:
            pass

    # Action buttons - anchored to bottom
    y = max_y - 1 - actions_height

    actions = [
        ("Resume session", "r"),
        ("View history", "h"),
    ]

    if y < max_y - 1:
        try:
            stdscr.addnstr(y, 2, "Actions:", max_x - 2, curses.A_BOLD)
        except curses.error:
            pass
        y += 1

    for idx, (label, key) in enumerate(actions):
        if y < max_y - 1:
            if idx == action_selected:
                attr = curses.color_pair(1) | curses.A_BOLD
                text = " > {} ({}) ".format(label, key)
            else:
                attr = curses.A_DIM
                text = "   {} ({})".format(label, key)
            try:
                if idx == action_selected:
                    stdscr.addnstr(y, 2, text.ljust(max_x - 4), max_x - 4, attr)
                else:
                    stdscr.addnstr(y, 2, text, max_x - 2, attr)
            except curses.error:
                pass
            y += 1

    # Footer
    footer = " \u2191\u2193/jk:switch  Enter/r:resume  h:history  Esc:back "
    try:
        stdscr.addnstr(max_y - 1, 0, footer.ljust(max_x), max_x, curses.A_REVERSE)
    except curses.error:
        pass


def _curses_text_input(stdscr, prompt, max_y, max_x):
    """Show a text input prompt at the bottom of the screen. Returns user input or None."""
    curses.curs_set(1)
    buf = ""

    while True:
        # Draw input bar
        input_line = "{} {}".format(prompt, buf)
        try:
            stdscr.addnstr(max_y - 2, 0, input_line.ljust(max_x), max_x,
                            curses.A_BOLD)
            stdscr.move(max_y - 2, len(prompt) + 1 + len(buf))
        except curses.error:
            pass
        stdscr.refresh()

        key = stdscr.getch()

        if key == 27:  # Esc
            curses.curs_set(0)
            return None
        elif key in (curses.KEY_ENTER, 10, 13):
            curses.curs_set(0)
            return buf.strip()
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            buf = buf[:-1]
        elif 32 <= key <= 126:
            buf += chr(key)


# Actions returned from the UI
ACTION_RESUME = "resume"
ACTION_HISTORY = "history"


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Browse, search, and resume Claude Code sessions."
    )
    parser.add_argument("-n", type=int, default=0, metavar="N",
                        help="Limit to N results")
    parser.add_argument("-s", type=str, default="", metavar="QUERY",
                        help="Start with search results for QUERY")
    parser.add_argument("--json", action="store_true", dest="json_out",
                        help="Output session list as JSON (non-interactive)")
    parser.add_argument("--full-path", action="store_true",
                        help="Don't shorten paths")
    parser.add_argument("--session", type=str, default="", metavar="ID",
                        help="Jump directly to action screen for session ID")
    parser.add_argument("--history", action="store_true",
                        help="With --session, print history directly")
    parser.add_argument("--no-tools", action="store_true",
                        help="Hide tool use/result blocks in history output")
    parser.add_argument("--thinking", action="store_true",
                        help="Include thinking blocks in history output")
    parser.add_argument("--no-color", action="store_true",
                        help="Disable colored output")

    args = parser.parse_args()

    # Collect sessions
    sessions = collect_sessions()
    sessions = filter_sessions(sessions)
    sessions = sort_sessions(sessions)

    if args.n > 0:
        sessions = sessions[:args.n]

    # Direct session ID mode
    if args.session:
        chosen = None
        for s in sessions:
            if s["session_id"] == args.session or s["session_id"].startswith(args.session):
                chosen = s
                break
        if not chosen:
            print("Session '{}' not found.".format(args.session), file=sys.stderr)
            sys.exit(1)

        if args.history:
            entries = read_session_history(
                chosen,
                include_thinking=args.thinking,
                include_tools=not args.no_tools,
            )
            if not entries:
                print("No messages found in session.", file=sys.stderr)
                sys.exit(1)
            use_color = sys.stdout.isatty() and not args.no_color
            print_history(chosen, entries, use_color=use_color)
        else:
            resume_session(chosen)
        return

    # JSON output mode
    if args.json_out:
        output = []
        for s in sessions:
            ts = s.get("last_timestamp") or s.get("timestamp")
            output.append({
                "session_id": s["session_id"],
                "project_path": s.get("project_path", ""),
                "display_path": shorten_path(s.get("project_path", ""), full=args.full_path),
                "description": session_description(s),
                "msg_count": s.get("msg_count", 0),
                "timestamp": ts.isoformat() if ts else None,
                "first_prompt": s.get("first_prompt", ""),
                "last_prompt": s.get("last_prompt", ""),
                "summary": s.get("summary", ""),
            })
        print(json.dumps(output, indent=2))
        return

    if not sessions:
        print("No sessions found.", file=sys.stderr)
        sys.exit(1)

    if not sys.stdout.isatty():
        # Non-interactive fallback
        for s in sessions:
            ts = s.get("last_timestamp") or s.get("timestamp")
            date_str = relative_date(ts)
            path_str = shorten_path(s.get("project_path", ""), full=args.full_path)
            desc = session_description(s)
            print("{} | {} | msgs: {}".format(date_str, path_str, s.get("msg_count", 0)))
            if desc:
                print("  {}".format(desc))
            print()
        return

    # If -s was given, start in search mode
    initial_search_terms = None
    if args.s:
        terms = [t.lower() for t in args.s.split()]
        print("Searching...", file=sys.stderr, end="", flush=True)
        results = search_all_sessions(terms)
        print(" {} results.".format(len(results)), file=sys.stderr)
        if results:
            sessions = results
            initial_search_terms = terms

    # For the curses UI, we need both the full list and any initial search results
    if initial_search_terms:
        all_sessions = collect_sessions()
        all_sessions = filter_sessions(all_sessions)
        all_sessions = sort_sessions(all_sessions)
    else:
        all_sessions = sessions

    def _run_ui(stdscr):
        curses.curs_set(0)
        curses.use_default_colors()

        curses.init_pair(1, curses.COLOR_WHITE, curses.COLOR_BLUE)
        curses.init_pair(2, curses.COLOR_YELLOW, -1)
        curses.init_pair(3, curses.COLOR_GREEN, -1)
        curses.init_pair(4, curses.COLOR_CYAN, -1)

        # State
        if initial_search_terms:
            mode = "search_results"
            display_sessions = sessions  # already search results
            search_terms = initial_search_terms
        else:
            mode = "list"
            display_sessions = all_sessions
            search_terms = None

        selected = 0
        offset = 0
        action_selected = 0
        chosen_session = None

        LINES_PER_ENTRY = 3

        while True:
            stdscr.erase()
            max_y, max_x = stdscr.getmaxyx()

            if mode == "action":
                _draw_action_screen(stdscr, chosen_session, max_y, max_x, action_selected)
                stdscr.refresh()
                key = stdscr.getch()

                if key == 27:
                    mode = "search_results" if search_terms else "list"
                    chosen_session = None
                    action_selected = 0
                elif key in (curses.KEY_UP, ord("k")):
                    action_selected = max(0, action_selected - 1)
                elif key in (curses.KEY_DOWN, ord("j")):
                    action_selected = min(1, action_selected + 1)
                elif key in (curses.KEY_ENTER, 10, 13):
                    if action_selected == 0:
                        return (chosen_session, ACTION_RESUME)
                    else:
                        return (chosen_session, ACTION_HISTORY)
                elif key == ord("r"):
                    return (chosen_session, ACTION_RESUME)
                elif key == ord("h"):
                    return (chosen_session, ACTION_HISTORY)
                elif key == ord("q"):
                    return (None, None)
                continue

            # List / search results
            if mode == "search_results":
                header = " Search: {} ({} results) ".format(
                    " ".join(search_terms) if search_terms else "", len(display_sessions)
                )
            else:
                header = " Claude Sessions ({} total) ".format(len(display_sessions))

            visible_entries = _draw_session_list(
                stdscr, display_sessions, selected, offset, max_y, max_x,
                header, search_mode=(mode == "search_results"),
                search_terms=search_terms,
            )

            stdscr.refresh()
            key = stdscr.getch()

            if mode == "search_results" and key == 27:
                mode = "list"
                display_sessions = all_sessions
                selected = 0
                offset = 0
                search_terms = None
                continue

            if key == ord("q"):
                return (None, None)
            if key == 27 and mode == "list":
                return (None, None)

            if key in (curses.KEY_DOWN, ord("j")):
                if display_sessions and selected < len(display_sessions) - 1:
                    selected += 1
            elif key in (curses.KEY_UP, ord("k")):
                if selected > 0:
                    selected -= 1
            elif key in (curses.KEY_NPAGE,):
                if display_sessions:
                    selected = min(selected + visible_entries, len(display_sessions) - 1)
            elif key in (curses.KEY_PPAGE,):
                selected = max(selected - visible_entries, 0)
            elif key in (curses.KEY_HOME, ord("g")):
                selected = 0
            elif key in (curses.KEY_END, ord("G")):
                if display_sessions:
                    selected = len(display_sessions) - 1

            elif key in (ord("s"), ord("/")):
                query = _curses_text_input(stdscr, "Search:", max_y, max_x)
                if query:
                    stdscr.erase()
                    try:
                        stdscr.addnstr(max_y // 2, 2,
                                       "Searching for: {} ...".format(query), max_x - 2)
                    except curses.error:
                        pass
                    stdscr.refresh()

                    terms = [t.lower() for t in query.split()]
                    results = search_all_sessions(terms)
                    if results:
                        display_sessions = results
                        search_terms = terms
                        mode = "search_results"
                        selected = 0
                        offset = 0
                    else:
                        try:
                            stdscr.addnstr(max_y // 2 + 1, 2,
                                           "No results found. Press any key.",
                                           max_x - 2, curses.A_BOLD)
                        except curses.error:
                            pass
                        stdscr.refresh()
                        stdscr.getch()

            elif key in (curses.KEY_ENTER, 10, 13):
                if display_sessions:
                    chosen_session = display_sessions[selected]
                    mode = "action"
                    action_selected = 0

            if selected < offset:
                offset = selected
            elif visible_entries > 0 and selected >= offset + visible_entries:
                offset = selected - visible_entries + 1

    result = curses.wrapper(_run_ui)
    session, action = result if result else (None, None)

    if not session:
        return

    if action == ACTION_RESUME:
        resume_session(session)
    elif action == ACTION_HISTORY:
        entries = read_session_history(
            session,
            include_thinking=args.thinking,
            include_tools=not args.no_tools,
        )
        if not entries:
            print("No messages found in session.", file=sys.stderr)
            sys.exit(1)
        use_color = sys.stdout.isatty() and not args.no_color
        print_history(session, entries, use_color=use_color)


if __name__ == "__main__":
    main()
